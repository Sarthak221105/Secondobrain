GCP_PROJECT_ID=lithe-booster-474607-d7
GCP_REGION=us-central1

# Auth is OFF by default in dev — the backend reads X-Dev-Role instead of
# verifying Firebase JWTs. Set AUTH_ENABLED=true to re-enable the real flow.
AUTH_ENABLED=false

FIREBASE_PROJECT_ID=ai-company-engine
FIREBASE_CREDENTIALS_PATH=/secrets/firebase.json

VERTEX_EMBEDDING_MODEL=text-embedding-004
VERTEX_GENERATION_MODEL=gemini-1.5-pro

PINECONE_API_KEY=
PINECONE_INDEX=enterprise-search
PINECONE_ENVIRONMENT=

ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=enterprise-search
ELASTICSEARCH_API_KEY=

# DLP is OFF by default for local dev. Set DLP_ENABLED=true in prod.
# When DLP_ENABLED=false the indexer uses a NoOp scanner (no PII redaction).
DLP_ENABLED=false
# DLP_INSPECT_TEMPLATE=
# DLP_DEIDENTIFY_TEMPLATE=

FIRESTORE_AUDIT_COLLECTION=audit_logs

CORS_ORIGINS=http://localhost:3000
